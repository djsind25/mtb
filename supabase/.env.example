# Copy to supabase/.env for local dev (supabase start / functions serve read it automatically).
# In production, set these with: supabase secrets set --env-file supabase/.env --project-ref <ref>
# (after filling in real values — never commit the real file).

# Stripe — plain PaymentIntents for the deposit charge. NOT Stripe Connect (out of scope for v1).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — transactional email for bid/chat/completion notifications.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=MyTrashBid <bids@mytrashbid.com>

# Shared secret Postgres uses (via pg_net) to call send-notification directly.
# Must match the `internal_dispatch_key` row in the app_config table exactly:
#   select value from app_config where key = 'internal_dispatch_key';
INTERNAL_DISPATCH_KEY=

# Base URL of the deployed front end, used to build links inside notification emails.
APP_URL=http://localhost:5173
