# Copy to .env for local dev. Values below match `npx supabase start`'s printed output
# (API_URL / ANON_KEY) — update after linking to a real project.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Publishable (pk_...) key only — the secret key must never reach the browser.
VITE_STRIPE_PUBLISHABLE_KEY=
